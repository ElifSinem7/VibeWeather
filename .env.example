# VibeWeather — Environment Variables
# Kopyala: cp .env.example .env

# OpenWeatherMap (ücretsiz tier yeterli)
# https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_owm_key_here

# Ollama model seçimi
# llama3.1:8b  → tool calling destekli, önerilen (5GB)
# llama3.2:3b  → daha hızlı, daha küçük (2GB)
# llama3.3:70b → en iyi kalite, güçlü GPU gerekir (40GB)
OLLAMA_MODEL=llama3.1:8b

# Visual Crossing (XGBoost eğitimi için — veri seti gelince)
VISUAL_CROSSING_API_KEY=your_vc_key_here
